# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

# Required: OpenRouter API key for all AI features (NL query, explainer, anomaly detector, etc.)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: override the default LLM model
# Default: anthropic/claude-haiku-4-5
# JANITOR_LLM_MODEL=anthropic/claude-haiku-4-5

# Optional: cloud provider backend
# Options: fixture (default), aws, gcp, azure
# JANITOR_BACKEND=fixture

# Optional: Terraform binary to use
# Options: tflocal (default, targets LocalStack), terraform (targets real AWS)
# TF_CMD=tflocal

# Optional: cron schedule for automated scans
# Default: disabled
# JANITOR_SCHEDULE=0 6 * * *
